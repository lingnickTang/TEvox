{
  "name": "evox-client",
  "displayName": "evox-client",
  "description": "",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/InfAGI/evox-ai.git"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "extension.openServerLogs",
        "title": "Open Server Logs"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agent-chat",
          "title": "Agent Chat",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "agent-chat": [
        {
          "type": "webview",
          "id": "agentChat",
          "name": "Agent Chat"
        }
      ]
    }
  },
  "scripts": {
    "compile": "npm run check-types && node esbuild.js",
    "check-types": "tsc --noEmit",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && node esbuild.js --production && vsce package",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "build:webview": "cd webview-ui && npm install && npm run build"
  },
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/express": "^4.17.21",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.96.0",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "esbuild": "^0.25.4",
    "eslint": "^9.17.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "@vscode/debugadapter": "^1.68.0",
    "axios": "^1.9.0",
    "express": "^4.21.2"
  }
}
